{
  "name": "nuxt-ui-vscode",
  "displayName": "Nuxt UI helper",
  "description": "Nuxt UI documentation and helpers inside VS Code",
  "version": "0.0.1",
  "publisher": "leVund",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "nuxt",
    "nuxt-ui",
    "vue",
    "documentation"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:vue"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nuxtUi",
          "title": "Nuxt UI",
          "icon": "resources/nuxt-ui-icon.svg"
        }
      ]
    },
    "views": {
      "nuxtUi": [
        {
          "type": "webview",
          "id": "nuxtUi.docView",
          "name": "Documentation"
        }
      ]
    },
    "configuration": {
      "title": "Nuxt UI helper",
      "properties": {
        "nuxtUi.version": {
          "type": "string",
          "enum": [
            "auto",
            "v3",
            "v4"
          ],
          "default": "auto",
          "description": "Which Nuxt UI documentation version to display. 'auto' reads the installed @nuxt/ui version from the workspace package.json."
        },
        "nuxtUi.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a CodeLens above lines containing Nuxt UI component tags."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
